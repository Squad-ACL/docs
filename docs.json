{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "sequoia",
  "name": "Product Guide",
  "description": "Step-by-step guides for every product—platform setup, analytics, and integrations in one place.",
  "colors": {
    "primary": "#f2cc0d",
    "light": "#f2cc0d",
    "dark": "#f2cc0d"
  },
  "favicon": {
    "light": "/images/squadacl-logo.png",
    "dark": "/images/squadacl-logo.png"
  },
  "icons": {
    "library": "tabler"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": [
      "copy",
      "view"
    ]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        }
      ]
    },
    "directory": "card",
    "groups": [
      {
        "group": "Platform",
        "icon": "layers",
        "expanded": true,
        "pages": [
          "platform/quickstart",
          "platform/key-concepts",
          "platform/configuration/settings",
          "platform/configuration/user-management",
          "platform/administration/roles-permissions"
        ]
      },
      {
        "group": "Analytics",
        "icon": "chart-bar",
        "expanded": true,
        "pages": [
          "analytics/quickstart",
          "analytics/connect-data",
          "analytics/dashboards/create-dashboard",
          "analytics/reports/scheduled-reports"
        ]
      },
      {
        "group": "Integrations",
        "icon": "plug",
        "expanded": true,
        "pages": [
          "integrations/quickstart",
          "integrations/authentication",
          "integrations/connectors/crm",
          "integrations/webhooks/configure"
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/squadacl-logo.png",
    "dark": "/images/squadacl-logo.png",
    "href": "https://squadacl.com"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "appearance": {
    "default": "dark"
  },
  "fonts": {
    "family": "Inter"
  }
}
